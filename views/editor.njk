{% extends "layouts/base.njk" %}

{% block content %}
<section class="py-5 bg-white" 
         x-data="posterEditor()" 
         x-init="initEditor()">
  <div class="container py-3">
    
    <!-- Title & Navigation -->
    <div class="row align-items-center justify-content-between mb-4 g-3">
      <div class="col-md-8">
        <h1 class="h2 text-navy fw-extrabold mb-1">Générateur d'Affiche Officiel</h1>
        <p class="text-muted mb-0">Créez votre affiche personnalisée et soutenez la campagne #JeChoisisLaVie</p>
      </div>
      <div class="col-md-4 text-md-end">
        <a href="/" class="btn btn-link text-navy text-decoration-none fw-semibold p-0">
          <i class="fa-solid fa-arrow-left me-2"></i> Retour à l'accueil
        </a>
      </div>
    </div>

    <!-- Main Editor Grid -->
    <div class="row g-4 items-start">
      
      <!-- Left Column: Controls (col-lg-5) -->
      <div class="col-lg-5 space-y-4">
        
        <!-- Step 1: Select Template -->
        <div class="card border shadow-sm rounded-4 p-4 mb-4 bg-light">
          <h2 class="h6 fw-bold text-navy text-uppercase tracking-wider mb-3 d-flex align-items-center gap-2">
            <span class="badge bg-navy text-white rounded-2 px-2 py-1" style="font-size: 10px;">1</span>
            Sélectionner un Modèle
          </h2>
          
          <div class="row g-2">
            {% for t in templates %}
              <div class="col-6">
                <button 
                  data-id="{{ t.id }}"
                  data-bg="{{ t.backgroundImage }}"
                  data-px="{{ t.photoX }}"
                  data-py="{{ t.photoY }}"
                  data-pw="{{ t.photoWidth }}"
                  data-ph="{{ t.photoHeight }}"
                  data-prot="{{ t.photoRotation }}"
                  data-texts="{{ t.texts | dump | escape }}"
                  @click="changeTemplate($event)"
                  :class="selectedTemplateId === '{{ t.id }}' ? 'border-warning border-3 bg-white' : 'border-light-subtle bg-white'"
                  class="btn p-2 rounded-3 w-100 text-center shadow-xs border">
                  <div class="ratio ratio-1x1 rounded-2 overflow-hidden bg-light mb-2">
                    <img src="{{ t.backgroundImage }}" alt="{{ t.name }}" class="object-fit-cover w-100 h-100 pointer-events-none">
                  </div>
                  <span class="small fw-semibold text-navy text-truncate d-block pointer-events-none" style="font-size: 11px;">{{ t.name }}</span>
                </button>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Step 2: Upload Photo -->
        <div class="card border shadow-sm rounded-4 p-4 mb-4 bg-light">
          <h2 class="h6 fw-bold text-navy text-uppercase tracking-wider mb-3 d-flex align-items-center gap-2">
            <span class="badge bg-navy text-white rounded-2 px-2 py-1" style="font-size: 10px;">2</span>
            Importer votre Photo
          </h2>
          
          <!-- Upload Box -->
          <div x-show="!photoUrl" class="border border-2 border-dashed border-secondary-subtle rounded-3 p-4 text-center cursor-pointer bg-white transition hover-border"
               @click="$refs.fileInput.click()"
               style="cursor: pointer;">
            <input type="file" x-ref="fileInput" class="d-none" accept="image/*" @change="handleFileUpload($event)">
            <i class="fa-solid fa-cloud-arrow-up text-muted display-6 mb-2"></i>
            <p class="small fw-bold text-navy mb-1">Cliquez pour choisir une photo</p>
            <p class="text-muted small mb-0" style="font-size: 11px;">Formats autorisés : PNG, JPG, WEBP (Max 5Mo)</p>
          </div>
          <style>
            .hover-border:hover {
              border-color: var(--yellow-gold) !important;
            }
          </style>

          <!-- Photo Options if Uploaded -->
          <div x-show="photoUrl" class="space-y-3">
            <div class="d-flex align-items-center justify-content-between border rounded-3 p-3 bg-white">
              <div class="d-flex align-items-center gap-2">
                <i class="fa-solid fa-circle-check text-success fs-5"></i>
                <div>
                  <p class="small fw-bold text-navy mb-0">Photo chargée avec succès</p>
                  <p class="text-muted mb-0 small text-truncate" style="max-width: 180px; font-size: 10px;" x-text="fileName"></p>
                </div>
              </div>
              <button @click="resetPhoto()" class="btn btn-link text-danger text-decoration-none fw-bold small p-0">
                <i class="fa-solid fa-trash-can me-1"></i> Supprimer
              </button>
            </div>

            <!-- Background Removal Settings -->
            <div class="border rounded-3 p-3 bg-white">
              <div class="d-flex align-items-center justify-content-between">
                <div class="pe-2">
                  <p class="small fw-bold text-navy mb-0">
                    <i class="fa-solid fa-wand-magic-sparkles text-gold me-1"></i> Détourer ma photo (Retirer le fond)
                  </p>
                  <p class="text-muted mb-0" style="font-size: 10px;">Utilise l'intelligence artificielle pour supprimer le fond.</p>
                </div>
                <div class="form-check form-switch mb-0">
                  <input class="form-check-input" type="checkbox" role="switch" x-model="removeBg" @change="toggleBgRemoval()" style="width: 2.2em; height: 1.2em; cursor: pointer;">
                </div>
              </div>

              <!-- Loader for background removal -->
              <div x-show="bgLoading" class="d-flex align-items-center gap-2 small text-muted mt-2" x-cloak>
                <i class="fa-solid fa-circle-notch fa-spin text-warning"></i>
                <span x-text="bgStatusText">Détourage en cours...</span>
              </div>
            </div>

            <!-- Photo Position Controls -->
            <div class="border rounded-3 p-3 bg-white">
              <p class="small fw-bold text-navy mb-3"><i class="fa-solid fa-sliders me-1"></i> Ajuster la photo</p>
              
              <div class="mb-3">
                <label class="form-label small text-muted d-flex justify-content-between mb-1">
                  <span>Zoom : <span x-text="zoom + '%'"></span></span>
                </label>
                <input type="range" min="10" max="400" x-model="zoom" @input="updateCanvas()" class="form-range">
              </div>

              <div class="mb-3">
                <label class="form-label small text-muted d-flex justify-content-between mb-1">
                  <span>Rotation : <span x-text="rotate + '°'"></span></span>
                </label>
                <input type="range" min="-180" max="180" x-model="rotate" @input="updateCanvas()" class="form-range">
              </div>

              <div class="row g-2 mb-2">
                <div class="col-6">
                  <label class="form-label small text-muted mb-1">Déplacement X</label>
                  <input type="range" min="-400" max="400" x-model="offsetX" @input="updateCanvas()" class="form-range">
                </div>
                <div class="col-6">
                  <label class="form-label small text-muted mb-1">Déplacement Y</label>
                  <input type="range" min="-400" max="400" x-model="offsetY" @input="updateCanvas()" class="form-range">
                </div>
              </div>
              
              <p class="text-muted small text-center mb-0 mt-2" style="font-size: 10px;">
                <i class="fa-solid fa-arrows-up-down-left-right me-1"></i> Vous pouvez aussi faire glisser l'image directement sur l'aperçu.
              </p>
            </div>
          </div>
        </div>

        <!-- Step 3: Custom Texts -->
        <div class="card border shadow-sm rounded-4 p-4 mb-4 bg-light">
          <h2 class="h6 fw-bold text-navy text-uppercase tracking-wider mb-3 d-flex align-items-center gap-2">
            <span class="badge bg-navy text-white rounded-2 px-2 py-1" style="font-size: 10px;">3</span>
            Personnaliser les Textes
          </h2>
          
          <div class="mb-3">
            <label class="form-label small text-navy fw-bold mb-1">Nom complet / Club Leo</label>
            <input type="text" x-model="name" @input="updateCanvas()" placeholder="Ex: LEONARD DE COTONOU" class="form-control rounded-3" maxlength="32">
          </div>
          
          <div class="mb-0">
            <label class="form-label small text-navy fw-bold mb-1">Ville / Zone</label>
            <input type="text" x-model="city" @input="updateCanvas()" placeholder="Ex: Cotonou" class="form-control rounded-3" maxlength="28">
          </div>
        </div>

        <!-- Submit Button -->
        <button 
          @click="submitPoster()"
          :disabled="!photoUrl || generating || bgLoading"
          :class="(!photoUrl || generating || bgLoading) ? 'opacity-50 cursor-not-allowed btn-secondary' : 'btn-gold shadow'"
          class="btn w-100 py-3 rounded-3 fw-bold fs-5 d-flex align-items-center justify-content-center gap-2 mb-4">
          <i class="fa-solid" :class="generating ? 'fa-spinner fa-spin' : 'fa-wand-magic-sparkles'"></i>
          <span x-text="generating ? 'Génération de l\'affiche...' : 'Générer mon Affiche'">Générer mon Affiche</span>
        </button>

      </div>
      
      <!-- Right Column: Canvas Live Preview (col-lg-7) -->
      <div class="col-lg-7 d-flex flex-column align-items-center">
        <div class="card border shadow-sm rounded-4 p-4 w-100 d-flex flex-column align-items-center justify-content-center bg-light">
          
          <span class="text-muted small text-uppercase tracking-wider fw-bold mb-3">Aperçu en temps réel</span>
          
          <!-- Canvas Wrapper with intrinsic scaling -->
          <div class="position-relative w-100 shadow-lg border rounded-3 overflow-hidden bg-dark" style="max-width: 420px;">
            <canvas id="editor-canvas" 
                    width="1080" 
                    height="1350" 
                    class="w-100 h-auto d-block"
                    style="cursor: move;"
                    @mousedown="startDrag($event)"
                    @mousemove="dragImage($event)"
                    @mouseup="endDrag()"
                    @mouseleave="endDrag()"
                    @touchstart="startDrag($event)"
                    @touchmove="dragImage($event)"
                    @touchend="endDrag()"></canvas>
            
            <!-- Default Placeholder when no photo is loaded -->
            <div x-show="!photoUrl" class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center bg-dark bg-opacity-75 p-4 text-center pointer-events-none" style="z-index: 5;">
              <div class="bg-navy text-warning rounded-4 d-flex align-items-center justify-content-center shadow mb-3" style="width: 56px; height: 56px;">
                <i class="fa-solid fa-image fs-3"></i>
              </div>
              <p class="fw-bold text-white mb-1">Votre Affiche Ici</p>
              <p class="text-white-50 small mb-0" style="max-width: 260px;">Importez votre photo sur la gauche pour commencer la composition.</p>
            </div>
            
            <!-- Absolute loading overlay -->
            <div x-show="generating" class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center bg-dark bg-opacity-90 text-center" style="z-index: 6;" x-cloak>
              <i class="fa-solid fa-spinner fa-spin text-warning display-5 mb-3"></i>
              <p class="fw-bold text-white mb-1">Création du fichier HD...</p>
              <p class="text-white-50 small mb-0">Sharp assemble les calques en haute résolution (1080x1350)</p>
            </div>
          </div>
          
          <div class="mt-3 text-center">
            <p class="text-muted small mb-0">Dimensions de l'affiche finale : 1080 x 1350 pixels (HD Portrait)</p>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<!-- Canvas script logic -->
<script>
  function posterEditor() {
    return {
      selectedTemplateId: '{{ activeTemplate.id }}',
      templateBg: '{{ activeTemplate.backgroundImage }}',
      photoX: {{ activeTemplate.photoX | default(0) }},
      photoY: {{ activeTemplate.photoY | default(0) }},
      photoWidth: {{ activeTemplate.photoWidth | default(0) }},
      photoHeight: {{ activeTemplate.photoHeight | default(0) }},
      photoRotation: {{ activeTemplate.photoRotation | default(0) }},
      texts: [],
      
      photoUrl: '',
      rawPhotoUrl: '',
      fileName: '',
      removeBg: false,
      bgLoading: false,
      bgStatusText: '',
      
      name: '',
      city: '',
      
      zoom: 100,
      rotate: 0,
      offsetX: 0,
      offsetY: 0,
      
      generating: false,
      
      templateImg: null,
      userImg: null,
      
      isDragging: false,
      dragStart: { x: 0, y: 0 },
      photoStartOffset: { x: 0, y: 0 },
      
      initEditor() {
        try {
          const rawTextsStr = '{{ activeTemplate.texts | dump | escape }}';
          const txtArea = document.createElement('textarea');
          txtArea.innerHTML = rawTextsStr;
          const parsed = JSON.parse(txtArea.value || '[]');
          this.texts = Array.isArray(parsed) ? parsed : [];
        } catch (e) {
          console.warn("Failed to parse template texts:", e);
          this.texts = [];
        }

        // Preload template background image
        this.loadTemplateImage();
      },
      
      loadTemplateImage() {
        this.templateImg = new Image();
        this.templateImg.onload = () => {
          if (!this.texts) this.texts = [];
          this.updateCanvas();
        };
        this.templateImg.src = this.templateBg;
      },
      
      changeTemplate(event) {
        const btn = event.currentTarget;
        
        this.selectedTemplateId = btn.dataset.id;
        this.templateBg = btn.dataset.bg;
        this.photoX = parseInt(btn.dataset.px) || 0;
        this.photoY = parseInt(btn.dataset.py) || 0;
        this.photoWidth = parseInt(btn.dataset.pw) || 0;
        this.photoHeight = parseInt(btn.dataset.ph) || 0;
        this.photoRotation = parseInt(btn.dataset.prot) || 0;
        
        try {
          const rawTexts = btn.dataset.texts || '[]';
          const txtArea = document.createElement('textarea');
          txtArea.innerHTML = rawTexts;
          const parsed = JSON.parse(txtArea.value);
          this.texts = Array.isArray(parsed) ? parsed : [];
        } catch (e) {
          console.warn("Failed to parse dynamic template texts:", e);
          this.texts = [];
        }
        
        this.loadTemplateImage();
      },
      
      handleFileUpload(event) {
        const file = event.target.files[0];
        if (!file) return;
        
        this.fileName = file.name;
        this.bgLoading = true;
        this.bgStatusText = "Téléchargement de la photo...";

        const formData = new FormData();
        formData.append('photo', file);
        formData.append('removeBg', this.removeBg);

        fetch('/editor/upload', {
          method: 'POST',
          body: formData
        })
        .then(res => res.json())
        .then(data => {
          if (data.error) {
            alert(data.error);
            this.resetPhoto();
          } else {
            this.photoUrl = data.photoUrl;
            this.rawPhotoUrl = data.photoUrl; // Cache raw upload
            this.loadUserImage();
          }
        })
        .catch(err => {
          console.error(err);
          alert("Erreur lors de l'upload de l'image.");
          this.resetPhoto();
        })
        .finally(() => {
          this.bgLoading = false;
        });
      },

      toggleBgRemoval() {
        if (!this.photoUrl) return;

        if (this.removeBg) {
          this.bgLoading = true;
          this.bgStatusText = "Suppression de l'arrière-plan par l'IA...";
          
          fetch('/editor/remove-bg-existing', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ photoPath: this.rawPhotoUrl })
          })
          .then(res => res.json())
          .then(data => {
            if (data.error) {
              alert(data.error);
              this.removeBg = false;
            } else {
              this.photoUrl = data.photoUrl;
              this.loadUserImage();
            }
          })
          .catch(err => {
            console.error(err);
            alert("Erreur lors de la suppression de l'arrière-plan.");
            this.removeBg = false;
          })
          .finally(() => {
            this.bgLoading = false;
          });
        } else {
          this.photoUrl = this.rawPhotoUrl;
          this.loadUserImage();
        }
      },
      
      loadUserImage() {
        this.userImg = new Image();
        this.userImg.onload = () => {
          const scale = Math.max(this.photoWidth / this.userImg.width, this.photoHeight / this.userImg.height);
          this.zoom = Math.round(scale * 100);
          this.offsetX = 0;
          this.offsetY = 0;
          this.rotate = 0;
          
          this.updateCanvas();
        };
        this.userImg.src = this.photoUrl;
      },
      
      resetPhoto() {
        this.photoUrl = '';
        this.rawPhotoUrl = '';
        this.fileName = '';
        this.userImg = null;
        this.removeBg = false;
        this.updateCanvas();
      },
      
      updateCanvas() {
        const canvas = document.getElementById('editor-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        
        // 1. Clear Canvas (White bg)
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        // 2. Draw User Photo (Behind cutout)
        if (this.userImg) {
          ctx.save();
          
          ctx.beginPath();
          ctx.rect(this.photoX, this.photoY, this.photoWidth, this.photoHeight);
          ctx.clip();
          
          const scale = this.zoom / 100;
          const rotatedWidth = this.userImg.width * scale;
          const rotatedHeight = this.userImg.height * scale;
          
          ctx.translate(
            this.photoX + this.photoWidth / 2 + parseInt(this.offsetX), 
            this.photoY + this.photoHeight / 2 + parseInt(this.offsetY)
          );
          
          ctx.rotate((parseInt(this.rotate) * Math.PI) / 180);
          
          ctx.drawImage(
            this.userImg, 
            -rotatedWidth / 2, 
            -rotatedHeight / 2, 
            rotatedWidth, 
            rotatedHeight
          );
          
          ctx.restore();
        }
        
        // 3. Draw Template Frame (With transparent viewport cutout)
        if (this.templateImg) {
          ctx.drawImage(this.templateImg, 0, 0, canvas.width, canvas.height);
        }
        
        // 4. Draw Dynamic Texts on top
        this.texts.forEach(text => {
          let textVal = '';
          if (text.type === 'NAME') textVal = this.name || 'VOTRE NOM';
          else if (text.type === 'CITY') textVal = this.city || 'VOTRE VILLE';
          else if (text.type === 'SLOGAN') textVal = 'JE CHOISIS LA VIE';
          
          if (!textVal) return;

          if (text.isUppercase) {
            textVal = textVal.toUpperCase();
          }
          
          ctx.font = `bold ${text.fontSize}px ${text.fontFamily}, Arial, sans-serif`;
          ctx.fillStyle = text.color;
          
          let textAnchor = 'center';
          let xPos = text.x + text.width / 2;
          if (text.align === 'left') {
            ctx.textAlign = 'left';
            xPos = text.x;
          } else if (text.align === 'right') {
            ctx.textAlign = 'right';
            xPos = text.x + text.width;
          } else {
            ctx.textAlign = 'center';
          }
          
          ctx.fillText(textVal, xPos, text.y);
        });
      },
      
      startDrag(event) {
        if (!this.userImg) return;
        this.isDragging = true;
        
        const clientX = event.touches ? event.touches[0].clientX : event.clientX;
        const clientY = event.touches ? event.touches[0].clientY : event.clientY;
        
        this.dragStart = { x: clientX, y: clientY };
        this.photoStartOffset = { x: parseInt(this.offsetX), y: parseInt(this.offsetY) };
      },
      
      dragImage(event) {
        if (!this.isDragging || !this.userImg) return;
        
        const clientX = event.touches ? event.touches[0].clientX : event.clientX;
        const clientY = event.touches ? event.touches[0].clientY : event.clientY;
        
        const canvasElement = document.getElementById('editor-canvas');
        const scaleFactor = canvasElement.width / canvasElement.clientWidth;
        
        const dx = (clientX - this.dragStart.x) * scaleFactor;
        const dy = (clientY - this.dragStart.y) * scaleFactor;
        
        this.offsetX = Math.round(this.photoStartOffset.x + dx);
        this.offsetY = Math.round(this.photoStartOffset.y + dy);
        
        this.updateCanvas();
      },
      
      endDrag() {
        this.isDragging = false;
      },
      
      submitPoster() {
        if (!this.photoUrl || this.generating) return;
        this.generating = true;
        
        const payload = {
          photoPath: this.photoUrl,
          templateId: this.selectedTemplateId,
          name: this.name,
          city: this.city,
          zoom: this.zoom / 100,
          rotate: this.rotate,
          offsetX: this.offsetX,
          offsetY: this.offsetY
        };
        
        fetch('/editor/generate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        })
        .then(res => res.json())
        .then(data => {
          if (data.error) {
            alert(data.error);
            this.generating = false;
          } else {
            window.location.href = `/gallery/share/${data.posterId}`;
          }
        })
        .catch(err => {
          console.error(err);
          alert("Erreur lors de la génération de l'affiche.");
          this.generating = false;
        });
      }
    };
  }
</script>
{% endblock %}

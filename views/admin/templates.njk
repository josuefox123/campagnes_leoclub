{% extends "layouts/admin.njk" %}

{% block content %}
<div class="space-y-8" x-data="{ openAdd: false }">
  
  <!-- Header -->
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-white">Modèles d'Affiches</h1>
      <p class="text-slate-400 mt-1">Configurez les visuels de fond, la zone photo et les positions de textes.</p>
    </div>
    <button @click="openAdd = !openAdd" class="bg-brand-600 hover:bg-brand-500 text-white rounded-2xl px-5 py-3 font-semibold text-sm transition flex items-center gap-2">
      <i class="fa-solid" :class="openAdd ? 'fa-minus' : 'fa-plus'"></i> Nouveau Modèle
    </button>
  </div>

  <!-- Add Template Form -->
  <div x-show="openAdd" x-collapse class="glass-dark border border-slate-900 rounded-3xl p-6 shadow-xl" x-cloak>
    <h2 class="text-base font-bold text-white mb-4">Créer un nouveau modèle</h2>
    <form action="/admin/templates/add" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label for="name" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Nom du Modèle</label>
        <input type="text" id="name" name="name" required placeholder="Ex: Modèle Officiel Slogan" class="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-700 focus:outline-none focus:border-brand-500 transition">
      </div>
      <div>
        <label for="campaignId" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Campagne Associée</label>
        <select id="campaignId" name="campaignId" required class="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 focus:outline-none focus:border-brand-500 transition">
          {% for campaign in campaigns %}
            <option value="{{ campaign.id }}">{{ campaign.name }}</option>
          {% endfor %}
        </select>
      </div>
      <div>
        <label for="width" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Largeur de l'affiche (px)</label>
        <input type="number" id="width" name="width" value="1080" required class="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 focus:outline-none focus:border-brand-500 transition">
      </div>
      <div>
        <label for="height" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Hauteur de l'affiche (px)</label>
        <input type="number" id="height" name="height" value="1350" required class="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 focus:outline-none focus:border-brand-500 transition">
      </div>
      <div class="md:col-span-2">
        <label for="backgroundImage" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Fond de l'affiche (PNG avec transparence recommandée)</label>
        <input type="file" id="backgroundImage" name="backgroundImage" required class="w-full text-slate-400 text-sm file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-slate-900 file:text-slate-300 file:cursor-pointer hover:file:bg-slate-800">
        <p class="text-[10px] text-slate-500 mt-2">Remarque : Pour un résultat optimal, l'image de fond doit disposer d'une zone transparente (un "trou") pour laisser transparaître la photo placée derrière.</p>
      </div>

      <div class="md:col-span-2 flex justify-end gap-3 pt-2">
        <button type="button" @click="openAdd = false" class="rounded-xl border border-slate-800 px-5 py-3 text-sm font-semibold text-slate-400 hover:text-white hover:bg-slate-900 transition">Annuler</button>
        <button type="submit" class="rounded-xl bg-brand-600 hover:bg-brand-500 px-5 py-3 text-sm font-semibold text-white transition">Créer &amp; Paramétrer les Zones</button>
      </div>
    </form>
  </div>

  <!-- Templates Grid List -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {% for t in templates %}
      <div class="glass-dark border border-slate-900 hover:border-slate-850 rounded-3xl overflow-hidden shadow-xl flex flex-col h-full group">
        <!-- Visual Preview Frame -->
        <div class="aspect-[4/5] bg-slate-950 border-b border-slate-900/60 overflow-hidden relative">
          <img src="{{ t.backgroundImage }}" alt="{{ t.name }}" class="w-full h-full object-cover">
          <div class="absolute top-4 left-4 bg-brand-600/90 text-white text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">
            {{ t.campaign.name }}
          </div>
          <!-- Action hover button -->
          <div class="absolute inset-0 bg-slate-950/80 opacity-0 group-hover:opacity-100 flex flex-col items-center justify-center p-6 transition duration-200">
            <p class="text-xs text-slate-400 font-semibold mb-4 text-center">Définissez visuellement l'emplacement de la photo et des textes.</p>
            <a href="/admin/templates/edit/{{ t.id }}" class="rounded-xl bg-white hover:bg-slate-200 text-slate-900 px-5 py-2.5 text-xs font-bold shadow-lg transition">
              <i class="fa-solid fa-crop-simple mr-1"></i> Zone Editor (Visual)
            </a>
          </div>
        </div>

        <!-- Meta Details -->
        <div class="p-5 flex-1 flex flex-col justify-between">
          <div>
            <h3 class="font-bold text-white text-base leading-snug">{{ t.name }}</h3>
            <p class="text-xs text-slate-500 mt-1 font-medium">{{ t.width }} x {{ t.height }} px</p>
          </div>

          <div class="mt-6 pt-4 border-t border-slate-900/60 flex items-center justify-between gap-4">
            <span class="text-xs text-slate-500 font-semibold uppercase">Configuration</span>
            <div class="flex gap-2">
              <a href="/admin/templates/edit/{{ t.id }}" class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-900 border border-slate-800 text-slate-400 hover:text-white hover:border-slate-700 transition">
                <i class="fa-solid fa-pen-to-square text-xs"></i>
              </a>
              <form action="/admin/templates/delete/{{ t.id }}" method="POST" class="inline-block" onsubmit="return confirm('Supprimer ce gabarit ? Toutes les affiches existantes générées avec ce modèle seront effacées !')">
                <button type="submit" class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-red-950/10 border border-red-900/20 text-red-400 hover:bg-red-950/20 transition">
                  <i class="fa-solid fa-trash-can text-xs"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

</div>
{% endblock %}

<!DOCTYPE html>
<html lang="fr" class="h-full bg-slate-950 text-slate-100 selection:bg-brand-500 selection:text-white">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Administration | STOP DROGUE TOUR</title>
  
  <!-- Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- CSS -->
  <link rel="stylesheet" href="/css/tailwind.css">
  
  <!-- Alpine JS -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, h4, h5, h6 { font-family: 'Space Grotesk', sans-serif; }
  </style>
</head>
<body class="h-full flex flex-col md:flex-row overflow-hidden bg-slate-950">

  <!-- Mobile Menu Trigger -->
  <div class="md:hidden bg-slate-900 border-b border-slate-800 p-4 flex justify-between items-center z-50">
    <a href="/" class="flex items-center gap-2 font-bold text-white">
      <i class="fa-solid fa-ribbon text-brand-500"></i> STOP DROGUE TOUR
    </a>
    <button @click="mobileOpen = !mobileOpen" x-data="{ mobileOpen: false }" class="text-slate-300 hover:text-white p-2">
      <i class="fa-solid fa-bars text-xl"></i>
    </button>
  </div>

  <!-- Sidebar Container -->
  <aside class="w-64 border-r border-slate-900 bg-slate-950 flex flex-col h-full shrink-0 z-40 hidden md:flex">
    <!-- Brand Info -->
    <div class="h-16 flex items-center gap-3 px-6 border-b border-slate-900">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-tr from-brand-600 to-red-500 text-white font-bold shadow-md">
        <i class="fa-solid fa-gauge-high text-sm"></i>
      </div>
      <span class="font-bold text-slate-100 tracking-wide text-sm uppercase">Administration</span>
    </div>
    
    <!-- User Badge -->
    <div class="p-4 border-b border-slate-900 flex items-center gap-3">
      <div class="h-10 w-10 rounded-full bg-brand-900 text-brand-300 flex items-center justify-center font-semibold">
        AD
      </div>
      <div>
        <p class="text-sm font-semibold text-white truncate max-w-[150px]">{{ currentUser.email }}</p>
        <span class="text-xs text-brand-400 font-medium">Administrateur</span>
      </div>
    </div>

    <!-- Navigation links -->
    <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
      <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition {% if currentPath === '/admin/dashboard' %}bg-slate-900 text-white border-l-4 border-brand-500{% else %}text-slate-400 hover:text-slate-200 hover:bg-slate-900/50{% endif %}">
        <i class="fa-solid fa-chart-line w-5 text-center"></i> Dashboard
      </a>
      <a href="/admin/campaigns" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition {% if currentPath === '/admin/campaigns' %}bg-slate-900 text-white border-l-4 border-brand-500{% else %}text-slate-400 hover:text-slate-200 hover:bg-slate-900/50{% endif %}">
        <i class="fa-solid fa-bullhorn w-5 text-center"></i> Campagnes
      </a>
      <a href="/admin/clubs" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition {% if currentPath === '/admin/clubs' %}bg-slate-900 text-white border-l-4 border-brand-500{% else %}text-slate-400 hover:text-slate-200 hover:bg-slate-900/50{% endif %}">
        <i class="fa-solid fa-users w-5 text-center"></i> Clubs Leo / Lions
      </a>
      <a href="/admin/templates" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition {% if currentPath.startsWith('/admin/templates') %}bg-slate-900 text-white border-l-4 border-brand-500{% else %}text-slate-400 hover:text-slate-200 hover:bg-slate-900/50{% endif %}">
        <i class="fa-solid fa-images w-5 text-center"></i> Modèles d'Affiches
      </a>
      <a href="/admin/posters" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition {% if currentPath === '/admin/posters' %}bg-slate-900 text-white border-l-4 border-brand-500{% else %}text-slate-400 hover:text-slate-200 hover:bg-slate-900/50{% endif %}">
        <i class="fa-solid fa-shield-halved w-5 text-center"></i> Modération Affiches
      </a>
      <a href="/admin/settings" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition {% if currentPath === '/admin/settings' %}bg-slate-900 text-white border-l-4 border-brand-500{% else %}text-slate-400 hover:text-slate-200 hover:bg-slate-900/50{% endif %}">
        <i class="fa-solid fa-sliders w-5 text-center"></i> Paramètres
      </a>
    </nav>

    <!-- Bottom Actions -->
    <div class="p-4 border-t border-slate-900 space-y-2">
      <a href="/" class="flex items-center justify-center gap-2 w-full px-4 py-2 rounded-xl text-xs font-semibold text-slate-400 bg-slate-900 border border-slate-800 hover:text-white hover:bg-slate-800 transition">
        <i class="fa-solid fa-eye"></i> Voir le site
      </a>
      <a href="/admin/logout" class="flex items-center justify-center gap-2 w-full px-4 py-2 rounded-xl text-xs font-semibold text-red-400 bg-red-950/10 border border-red-900/20 hover:bg-red-950/20 transition">
        <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
      </a>
    </div>
  </aside>

  <!-- Main Content Wrapper -->
  <div class="flex-1 flex flex-col h-full overflow-hidden bg-slate-950">
    <main class="flex-1 overflow-y-auto px-6 py-8">
      <div class="mx-auto max-w-6xl">
        {% block content %}{% endblock %}
      </div>
    </main>
  </div>

</body>
</html>

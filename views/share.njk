{% extends "layouts/base.njk" %}

{% block block_id %}share-view{% endblock %}

{% block meta %}
  <!-- OpenGraph Metadata for Social Media Previews -->
  <meta property="og:title" content="Je soutiens la campagne STOP DROGUE TOUR 2026 !">
  <meta property="og:description" content="Découvrez mon affiche officielle de sensibilisation. Faites comme moi, dites NON à la drogue et choisissez la vie.">
  <meta property="og:image" content="{{ fullPosterUrl }}">
  <meta property="og:url" content="{{ shareUrl }}">
  <meta property="og:type" content="article">
  
  <!-- Twitter Card Metadata -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Je soutiens la campagne STOP DROGUE TOUR 2026 !">
  <meta name="twitter:description" content="Générez votre affiche de campagne officielle personnalisée en quelques secondes.">
  <meta name="twitter:image" content="{{ fullPosterUrl }}">
{% endblock %}

{% block content %}
<section class="py-5 bg-white" 
         x-data="shareComponent('{{ poster.id }}', '{{ poster.filename }}', '{{ shareUrl }}', '{{ poster.name | default('Sensibilisation') }}')">
  <div class="container py-3" style="max-width: 900px;">
    
    <div class="text-center mb-5">
      <div class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px;">
        <i class="fa-solid fa-circle-check fs-3"></i>
      </div>
      <h1 class="h2 text-navy fw-bold mb-2">Affiche Générée avec Succès !</h1>
      <p class="text-muted mx-auto mb-0" style="max-width: 600px;">Votre affiche officielle pour la campagne <strong>STOP DROGUE TOUR 2026</strong> est prête. Téléchargez-la et partagez-la pour faire connaître le mouvement.</p>
    </div>

    <!-- Content Grid -->
    <div class="row g-5 align-items-center">
      
      <!-- Left: Poster Display Card -->
      <div class="col-md-6 d-flex justify-content-center">
        <div class="card border shadow-lg rounded-4 p-2 bg-white" style="max-width: 320px; width: 100%;">
          <img src="{{ poster.filename }}" alt="Votre Affiche STOP DROGUE TOUR" class="img-fluid rounded-3 border">
        </div>
      </div>

      <!-- Right: Share Controls -->
      <div class="col-md-6 space-y-4">
        
        <div class="card border shadow-sm rounded-4 p-4 mb-4 bg-light">
          <h2 class="h6 fw-bold text-navy mb-3">Actions rapides</h2>
          
          <!-- Download Button -->
          <a href="{{ poster.filename }}" download="Affiche_Stop_Drogue_{{ poster.name | default('Sensibilisation') }}.png" @click="incrementDownload()" class="btn btn-gold w-100 py-3 rounded-3 fw-bold fs-5 mb-3 shadow-xs">
            <i class="fa-solid fa-download me-2"></i> Télécharger en HD
          </a>

          <!-- Native/Mobile Share Button (Web Share API) -->
          <button @click="shareNative()" class="btn btn-navy w-100 py-3 rounded-3 fw-bold fs-5 shadow-xs">
            <i class="fa-solid fa-share-nodes me-2"></i> Partager l'affiche
          </button>
        </div>

        <!-- Social Networks Specific Buttons -->
        <div class="card border shadow-sm rounded-4 p-4 mb-4 bg-light">
          <h2 class="text-muted small text-uppercase tracking-wider fw-bold mb-3">Partager sur vos réseaux</h2>
          
          <div class="row g-2">
            <div class="col-4">
              <button @click="shareWhatsApp()" class="btn btn-white border w-100 py-3 rounded-3 text-center d-flex flex-column align-items-center justify-content-center gap-1.5 shadow-sm">
                <i class="fa-brands fa-whatsapp text-success fs-3"></i>
                <span class="small fw-semibold text-navy" style="font-size: 11px;">WhatsApp</span>
              </button>
            </div>
            <div class="col-4">
              <button @click="shareFacebook()" class="btn btn-white border w-100 py-3 rounded-3 text-center d-flex flex-column align-items-center justify-content-center gap-1.5 shadow-sm">
                <i class="fa-brands fa-facebook text-primary fs-3"></i>
                <span class="small fw-semibold text-navy" style="font-size: 11px;">Facebook</span>
              </button>
            </div>
            <div class="col-4">
              <button @click="shareTwitter()" class="btn btn-white border w-100 py-3 rounded-3 text-center d-flex flex-column align-items-center justify-content-center gap-1.5 shadow-sm">
                <i class="fa-brands fa-x-twitter text-dark fs-3"></i>
                <span class="small fw-semibold text-navy" style="font-size: 11px;">X (Twitter)</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Viral QR Explanation -->
        <div class="card border border-warning rounded-4 p-4 bg-warning bg-opacity-10 mb-4">
          <div class="d-flex align-items-start gap-3">
            <div class="bg-warning text-navy rounded-3 p-2">
              <i class="fa-solid fa-qrcode fs-4"></i>
            </div>
            <div>
              <h3 class="h6 fw-bold text-navy mb-1">QR Code d'invitation inclus !</h3>
              <p class="text-muted small mb-0" style="font-size: 12px; line-height: 1.45;">
                Vos amis peuvent scanner le code figurant en bas à droite de votre affiche pour accéder instantanément au générateur et créer la leur.
              </p>
            </div>
          </div>
        </div>

        <!-- Action to create a new one -->
        <div class="text-center pt-2">
          <a href="/editor" class="text-navy text-decoration-none fw-bold small">
            <i class="fa-solid fa-wand-magic-sparkles text-gold me-2"></i> Générer une autre affiche
          </a>
        </div>

      </div>

    </div>
  </div>
</section>

<!-- Alpine Component Script -->
<script>
  function shareComponent(posterId, filename, shareUrl, name) {
    return {
      downloadCount: 0,
      shareCount: 0,
      
      incrementDownload() {
        fetch(`/gallery/download/${posterId}`, { method: 'POST' })
          .catch(e => console.error("Failed to track download:", e));
      },
      
      incrementShare() {
        fetch(`/gallery/share-click/${posterId}`, { method: 'POST' })
          .catch(e => console.error("Failed to track share:", e));
      },

      shareNative() {
        this.incrementShare();
        if (navigator.share) {
          navigator.share({
            title: 'Campagne STOP DROGUE TOUR 2026',
            text: `Je soutiens la campagne ! Voici mon affiche de sensibilisation. Faites comme moi, dites NON à la drogue et choisissez la vie !`,
            url: shareUrl
          }).catch(err => console.log('Error sharing:', err));
        } else {
          // Fallback to copying link
          navigator.clipboard.writeText(shareUrl).then(() => {
            alert('Lien de partage copié dans le presse-papier !');
          });
        }
      },

      shareWhatsApp() {
        this.incrementShare();
        const text = encodeURIComponent(`Je soutiens la campagne STOP DROGUE TOUR 2026 ! Voici mon affiche personnalisée. Faites comme moi, dites non à la drogue, choisissez la vie ! Créez la vôtre ici : ${shareUrl}`);
        window.open(`https://api.whatsapp.com/send?text=${text}`, '_blank');
      },

      shareFacebook() {
        this.incrementShare();
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`, '_blank');
      },

      shareTwitter() {
        this.incrementShare();
        const text = encodeURIComponent(`Dites NON à la drogue, choisissez la vie. Voici mon affiche officielle pour la campagne #STOPDROGUETOUR2026 #JeChoisisLaVie ! Créez la vôtre :`);
        window.open(`https://twitter.com/intent/tweet?text=${text}&url=${encodeURIComponent(shareUrl)}`, '_blank');
      }
    };
  }
</script>
{% endblock %}

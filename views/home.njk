{% extends "layouts/base.njk" %}

{% block content %}
<!-- Hero Section -->
<section class="py-5 py-md-5 bg-light position-relative overflow-hidden border-bottom">
  <div class="container py-4 py-md-5">
    <div class="row align-items-center justify-content-center text-center">
      <div class="col-lg-10">
        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 mb-4 text-uppercase fw-bold">
          Campagne Officielle 2026
        </span>
        
        <h1 class="display-3 fw-bold text-navy mb-4 leading-tight">
          Dites <span class="text-danger">NON</span> à la Drogue,<br>
          <span class="border-bottom border-warning border-4">Choisissez Votre Avenir.</span>
        </h1>
        
        <p class="lead text-muted mx-auto mb-5 max-w-2xl" style="max-width: 700px;">
          Générez votre affiche de campagne officielle personnalisée en quelques secondes, supprimez automatiquement l'arrière-plan de votre photo grâce à l'IA et soutenez le mouvement pour sensibiliser la jeunesse.
        </p>
        
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
          <a href="/editor" class="btn btn-gold px-5 py-3 rounded-3 shadow fs-5">
            <i class="fa-solid fa-wand-magic-sparkles me-2"></i> Créer mon affiche
          </a>
          <a href="#gallery" class="btn btn-navy px-5 py-3 rounded-3 shadow fs-5">
            <i class="fa-solid fa-images me-2"></i> Parcourir la galerie
          </a>
        </div>
        
        <!-- Mini statistics banner -->
        <div class="row justify-content-center g-4 mt-5">
          <div class="col-12 col-md-8">
            <div class="card border-0 bg-white shadow-sm rounded-4 p-4">
              <div class="row align-items-center justify-content-around g-3 text-center">
                <div class="col-sm-4">
                  <p class="h2 fw-bold text-navy mb-0">100%</p>
                  <p class="text-muted small text-uppercase fw-semibold mb-0">Gratuit &amp; Privé</p>
                </div>
                <div class="col-sm-1 d-none d-sm-block text-muted">|</div>
                <div class="col-sm-4">
                  <p class="h2 fw-bold text-navy mb-0">IA</p>
                  <p class="text-muted small text-uppercase fw-semibold mb-0">Détourage local</p>
                </div>
                <div class="col-sm-1 d-none d-sm-block text-muted">|</div>
                <div class="col-sm-3">
                  <p class="h2 fw-bold text-navy mb-0">HD</p>
                  <p class="text-muted small text-uppercase fw-semibold mb-0">Haute Résolution</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>

<!-- Campaign Info Section -->
<section class="py-5 bg-white">
  <div class="container py-4">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <h2 class="h1 text-navy mb-4">
          Qu'est-ce que le STOP DROGUE TOUR ?
        </h2>
        <p class="lead text-muted mb-4">
          Le <strong>STOP DROGUE TOUR 2026</strong> est une initiative de sensibilisation d'envergure organisée par la <strong>Région 14 – District Leo 403 A4 Bénin</strong>. Cette action vise à mobiliser la jeunesse de nos communes afin de freiner la propagation des stupéfiants et de susciter une prise de conscience collective.
        </p>
        <p class="text-muted mb-4">
          À travers ce générateur d'affiches, devenez un relais actif de notre message. Prêtez votre voix et votre image pour dire oui à la vie et non à la drogue !
        </p>
        
        <div class="row g-4 mt-2">
          <div class="col-sm-6">
            <div class="d-flex align-items-start gap-3">
              <div class="bg-danger-subtle text-danger rounded-3 p-2">
                <i class="fa-solid fa-heart fs-4"></i>
              </div>
              <div>
                <p class="fw-bold mb-0 text-navy">Devise de l'action</p>
                <p class="text-muted small mb-0">« Unis par le Cœur, Engagés pour l'Impact »</p>
              </div>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="d-flex align-items-start gap-3">
              <div class="bg-success-subtle text-success rounded-3 p-2">
                <i class="fa-solid fa-calendar-days fs-4"></i>
              </div>
              <div>
                <p class="fw-bold mb-0 text-navy">Dates</p>
                <p class="text-muted small mb-0">24 &amp; 25 Juillet 2026</p>
              </div>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="d-flex align-items-start gap-3">
              <div class="bg-primary-subtle text-primary rounded-3 p-2">
                <i class="fa-solid fa-map-location-dot fs-4"></i>
              </div>
              <div>
                <p class="fw-bold mb-0 text-navy">Zones d'Exécution</p>
                <p class="text-muted small mb-0">Cotonou et Porto-Novo (Bénin)</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Visual Showcase Card -->
      <div class="col-lg-6 d-flex justify-content-center">
        <div class="position-relative">
          <div class="position-absolute bg-warning-subtle rounded-circle blur-3xl opacity-50" style="width: 300px; height: 300px; z-index: 1; top: -50px; left: -50px; filter: blur(50px);"></div>
          <div class="card border shadow-lg rounded-4 p-3 bg-white rotate-3 position-relative" style="max-width: 340px; transform: rotate(3deg); z-index: 2;">
            <img src="/uploads/templates/default_template.png" alt="Affiche exemple" class="img-fluid rounded-3 border">
            <div class="position-absolute bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow-lg" style="width: 48px; height: 48px; bottom: 24px; right: 24px; z-index: 3;">
              <i class="fa-solid fa-check fs-5"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Gallery Showcase Section -->
<section id="gallery" class="py-5 bg-light border-top">
  <div class="container py-4">
    <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between mb-5">
      <div>
        <h2 class="h1 text-navy mb-0">Galerie des participants</h2>
        <p class="text-muted mt-2">Découvrez les affiches partagées par ceux qui soutiennent la campagne.</p>
      </div>
      <a href="/gallery" class="btn btn-outline-navy mt-3 mt-md-0 fw-semibold">
        Voir toutes les affiches <i class="fa-solid fa-arrow-right-long ms-2"></i>
      </a>
    </div>

    {% if recentPosters.length > 0 %}
      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
        {% for poster in recentPosters %}
          <div class="col">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative group">
              <div class="ratio ratio-4x5 overflow-hidden bg-dark position-relative">
                <img src="{{ poster.filename }}" alt="Affiche de {{ poster.name }}" class="object-fit-cover w-100 h-100 transition-all duration-300">
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 opacity-0 hover-opacity-100 d-flex align-items-end p-4 transition-all duration-200" style="z-index: 3;">
                  <a href="/gallery/share/{{ poster.id }}" class="btn btn-light w-100 py-2 rounded-3 fw-bold shadow">
                    <i class="fa-solid fa-share-nodes me-2"></i> Voir et Partager
                  </a>
                </div>
              </div>
              <style>
                .hover-opacity-100:hover {
                  opacity: 1 !important;
                }
              </style>
              <div class="card-body p-4 bg-white">
                <h5 class="card-title text-navy text-truncate mb-1">{{ poster.name | default("Soutien de la campagne") }}</h5>
                <p class="card-text text-muted small text-truncate mb-0">{{ poster.city | default("Bénin") }}</p>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="text-center py-5 border border-dashed rounded-4 bg-white shadow-sm">
        <i class="fa-solid fa-images text-muted display-4 mb-3"></i>
        <p class="text-muted">Aucune affiche n'a encore été générée. Soyez le premier !</p>
        <a href="/editor" class="btn btn-gold px-4 py-2 mt-2 rounded-3">
          Créer mon affiche
        </a>
      </div>
    {% endif %}
  </div>
</section>

<!-- Participating Clubs section -->
<section class="py-5 bg-white border-top">
  <div class="container py-4 text-center">
    <h2 class="h5 text-muted text-uppercase tracking-wider fw-bold mb-5">Clubs organisateurs de la Région 14</h2>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 justify-content-center">
      {% for club in clubs %}
        <div class="col" style="max-width: 280px;">
          <div class="card h-100 border-0 bg-light p-4 rounded-4 text-center d-flex flex-column align-items-center justify-content-center shadow-sm">
            <img src="{{ club.logo | default('/images/logo-placeholder.png') }}" alt="{{ club.name }}" class="img-fluid mb-3 object-fit-contain" style="height: 70px;">
            <h3 class="h6 text-navy fw-bold mb-1" style="font-size: 14px;">{{ club.name }}</h3>
            <p class="text-muted small mb-0 fw-semibold">{{ club.city }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}

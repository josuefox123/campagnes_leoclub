{
  "name": "stop-drogue-tour-2026",
  "version": "1.0.0",
  "description": "Campaign Poster Generator for STOP DROGUE TOUR 2026",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch-path=./server.js --watch-path=./controllers --watch-path=./middleware --watch-path=./routes --watch-path=./views server.js",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --watch"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "prisma": "^5.12.1",
    "tailwindcss": "^3.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
